---
import PostLayout from '@layouts/PostLayout.astro';
import { getDestinationPosts, getPostBySlug } from '@/data/posts';

export function getStaticPaths() {
  return getDestinationPosts('en').map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = slug ? getPostBySlug(slug, 'en') : undefined;

if (!post || post.route !== 'destinations') {
  return Astro.redirect('/404/');
}
---
<PostLayout post={post} lang="en" />
