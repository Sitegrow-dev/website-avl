---
import PageLayout from '@layouts/PageLayout.astro';
import ContactSection from '@components/ContactSection.astro';
import { siteConfig } from '@/config/site';
import { getContactContent } from '@/data/contact';
import { breadcrumbTrails } from '@/lib/breadcrumb';

const content = getContactContent('en');
---
<PageLayout
  lang="en-CA"
  title={`${content.title} | ${siteConfig.siteName}`}
  description={content.subtitle}
  breadcrumbs={breadcrumbTrails.contact('en')}
  activeHref="/en/contact/"
>
  <main>
    <ContactSection />
  </main>
</PageLayout>
