---
import PageLayout from '@layouts/PageLayout.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import { getPhotosContent } from '@/data/photos';
import { breadcrumbTrails } from '@/lib/breadcrumb';
import { localizedHref } from '@/lib/i18n';

const lang = 'en' as const;
const brandEyebrow = 'American Friends of the Vatican Library';
const { title, metaTitle, metaDescription, intro, archiveNote, galleryHeading, images, cta } =
  getPhotosContent(lang);
---
<PageLayout
  lang="en-CA"
  title={metaTitle}
  description={metaDescription}
  breadcrumbs={breadcrumbTrails.photosHtm(lang)}
  activeHref="/en/photos.htm"
  canonicalPath="/en/photos.htm"
>
  <main>
    <section class="px-5 pb-10 pt-16 sm:px-8 sm:pb-12 sm:pt-20 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-brand">{brandEyebrow}</p>
        <h1 class="mt-4 font-display text-4xl leading-tight text-ink sm:text-5xl lg:text-[52px] lg:leading-[1.1]">
          {title}
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-muted">{intro}</p>
      </div>
    </section>

    <section class="border-y border-black/[0.08] bg-surface px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{archiveNote.title}</h2>
        {archiveNote.paragraphs.map((paragraph) => (
          <p class="mt-5 text-lg leading-relaxed text-muted">{paragraph}</p>
        ))}
      </div>
    </section>

    <section class="px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
      <div class="mx-auto max-w-5xl">
        <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{galleryHeading}</h2>
        <div class="mt-10 grid grid-cols-1 gap-10 md:grid-cols-2">
          {images.map((image, index) => (
            <figure class:list={[index === 0 && 'md:col-span-2']}>
              <div class="overflow-hidden bg-bg-alt">
                <ResponsiveImage
                  src={image.src}
                  alt={image.alt}
                  width={image.width}
                  height={image.height}
                  sizes={index === 0 ? '(min-width: 1024px) 64rem, 100vw' : '(min-width: 768px) 28rem, 100vw'}
                  class={
                    index === 0
                      ? 'h-auto w-full object-contain'
                      : 'mx-auto h-auto w-full max-w-[200px] object-contain'
                  }
                  loading={index === 0 ? 'eager' : 'lazy'}
                  fetchpriority={index === 0 ? 'high' : undefined}
                />
              </div>
              <figcaption class="mt-3 text-sm leading-relaxed text-muted">{image.caption}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-black/[0.08] bg-surface px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-lg leading-relaxed text-muted">{cta.text}</p>
        <a
          href={localizedHref(cta.button.href, lang)}
          class="mt-8 inline-flex items-center justify-center rounded-md bg-brand px-7 py-3.5 text-base font-semibold text-white shadow-[0_4px_7px_rgba(0,0,0,0.1)] transition-colors hover:bg-brand-hover"
        >
          {cta.button.label}
        </a>
      </div>
    </section>
  </main>
</PageLayout>
