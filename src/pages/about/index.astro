---
import PageLayout from '@layouts/PageLayout.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import { siteConfig } from '@/config/site';
import { getAboutContent } from '@/data/about';
import { breadcrumbTrails } from '@/lib/breadcrumb';
import { localizedHref } from '@/lib/i18n';

const lang = 'fr' as const;
const {
  title,
  brandEyebrow,
  metaDescription,
  intro,
  history,
  executive,
  termBoard,
  honoraryBoard,
  cta,
} = getAboutContent(lang);
---
<PageLayout
  lang="fr-CA"
  title={`${title} | ${siteConfig.siteName}`}
  description={metaDescription}
  breadcrumbs={breadcrumbTrails.aboutHtm(lang)}
  activeHref="/about.htm"
  canonicalPath="/about.htm"
>
  <main>
    <section class="px-5 pb-10 pt-16 sm:px-8 sm:pb-12 sm:pt-20 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.12em] text-brand">{brandEyebrow}</p>
        <h1 class="mt-4 font-display text-4xl leading-tight text-ink sm:text-5xl lg:text-[52px] lg:leading-[1.1]">
          {title}
        </h1>
        {intro.map((paragraph) => (
          <p class="mt-6 text-lg leading-relaxed text-muted">{paragraph}</p>
        ))}
      </div>
    </section>

    <section class="border-y border-black/[0.08] bg-surface px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <ResponsiveImage
          src="/images/archive/afvl-header"
          alt={brandEyebrow}
          width={860}
          height={130}
          sizes="(min-width: 768px) 48rem, 100vw"
          class="h-auto w-full"
          loading="eager"
          fetchpriority="high"
        />
        <h2 class="mt-10 font-display text-3xl leading-tight text-ink sm:text-4xl">{history.title}</h2>
        {history.paragraphs.map((paragraph) => (
          <p class="mt-5 text-lg leading-relaxed text-muted">{paragraph}</p>
        ))}
      </div>
    </section>

    <section class="px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
      <div class="mx-auto max-w-5xl">
        <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{executive.title}</h2>
        <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-3">
          {executive.items.map((item) => (
            <article>
              <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">{item.role}</p>
              <h3 class="mt-2 text-xl font-bold text-ink">{item.name}</h3>
              <ul class="mt-3 space-y-0.5 text-base leading-relaxed text-muted">
                {item.lines.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-y border-black/[0.08] bg-surface px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
      <div class="mx-auto max-w-5xl">
        <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{termBoard.title}</h2>
        <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {termBoard.items.map((member) => (
            <article>
              <h3 class="text-base font-bold text-ink">{member.name}</h3>
              <ul class="mt-2 space-y-0.5 text-sm leading-relaxed text-muted">
                {member.lines.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
      <div class="mx-auto max-w-5xl">
        <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{honoraryBoard.title}</h2>
        <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {honoraryBoard.items.map((member) => (
            <article>
              <h3 class="text-base font-bold text-ink">{member.name}</h3>
              <ul class="mt-2 space-y-0.5 text-sm leading-relaxed text-muted">
                {member.lines.map((line) => (
                  <li>{line}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-black/[0.08] bg-surface px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
      <div class="mx-auto flex max-w-3xl flex-col items-center gap-8 text-center sm:flex-row sm:text-left">
        <picture class="shrink-0">
          <source srcset="/images/archive/afvl-xxv-anniversary.avif" type="image/avif" />
          <source srcset="/images/archive/afvl-xxv-anniversary.webp" type="image/webp" />
          <img
            src="/images/archive/afvl-xxv-anniversary.webp"
            alt="AFVL 25th anniversary"
            width="128"
            height="171"
            class="mx-auto h-auto w-28"
            loading="lazy"
            decoding="async"
          />
        </picture>
        <div>
          <p class="text-lg leading-relaxed text-muted">{cta.text}</p>
          <a
            href={localizedHref(cta.button.href, lang)}
            class="mt-6 inline-flex items-center justify-center rounded-md bg-brand px-7 py-3.5 text-base font-semibold text-white shadow-[0_4px_7px_rgba(0,0,0,0.1)] transition-colors hover:bg-brand-hover"
          >
            {cta.button.label}
          </a>
        </div>
      </div>
    </section>
  </main>
</PageLayout>
