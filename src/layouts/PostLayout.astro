---
import PageLayout from '@layouts/PageLayout.astro';
import JsonLd from '@components/JsonLd.astro';
import PostHero from '@components/post/PostHero.astro';
import PostBody from '@components/post/PostBody.astro';
import FinalCtaSection from '@components/shared/FinalCtaSection.astro';
import { breadcrumbTrails } from '@/lib/breadcrumb';
import { buildArticleGraph, buildFaqSchema } from '@/lib/schema';
import { formatTitle } from '@/lib/seo';
import { getPostHref, getPostRoute, type Post } from '@/data/posts';
import type { Lang } from '@/lib/i18n';

interface Props {
  post: Post;
  lang?: Lang;
}

const { post, lang = 'fr' } = Astro.props;

const origin = Astro.site ?? new URL(Astro.url.origin);
const path = getPostHref({ ...post, published: true });
const route = getPostRoute(post);
const isRoot = route === 'root';
const isDestination = route === 'destinations';
const ampUrl =
  lang === 'fr' && !isDestination
    ? new URL(isRoot ? `/${post.slug}/amp/` : `/blog/${post.slug}/amp/`, origin).href
    : undefined;
const articleGraph = buildArticleGraph(post, origin, {
  path,
  lang: lang === 'en' ? 'en-CA' : 'fr-CA',
});
const faqSchema = post.faq?.length ? buildFaqSchema(post.faq) : null;
const breadcrumbs = isDestination
  ? breadcrumbTrails.destination(post.title, lang)
  : isRoot
    ? breadcrumbTrails.guide(post.title, lang)
    : breadcrumbTrails.post(post.title, lang);
---
<PageLayout
  lang={lang === 'en' ? 'en-CA' : 'fr-CA'}
  title={formatTitle(post.metaTitle || post.title)}
  description={post.summary}
  image={
    post.image
      ? /^https?:\/\//i.test(post.image)
        ? post.image
        : `${post.image}.webp`
      : undefined
  }
  imageAlt={post.imageAlt}
  type="article"
  ampUrl={ampUrl}
  breadcrumbs={breadcrumbs}
  activeHref={path}
  canonicalPath={path}
>
  <JsonLd schema={articleGraph} />
  {faqSchema && <JsonLd schema={faqSchema} />}
  <main>
    <PostHero post={post} lang={lang} />
    <PostBody post={post} lang={lang} />
    <FinalCtaSection />
  </main>
</PageLayout>
