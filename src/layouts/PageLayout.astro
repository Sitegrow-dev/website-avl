---
import '@/styles/global.css';
import FaviconHead from '@components/FaviconHead.astro';
import SeoHead from '@components/SeoHead.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import type { BreadcrumbItem } from '@/lib/breadcrumb';
import { DEFAULT_ROBOTS } from '@/lib/seo';
import { siteConfig } from '@/config/site';
import HomeNavigation from '@components/home/HomeNavigation.astro';
import HomeFooter from '@components/home/HomeFooter.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  robots?: string;
  /** Image OG/canonique (chemin relatif type /images/blog/slug.webp) */
  image?: string;
  /** Texte alternatif de l'image OG (défaut = titre). */
  imageAlt?: string;
  /** Type OG — 'article' pour les posts, 'website' par défaut */
  type?: 'website' | 'article';
  /** URL AMP à déclarer via <link rel="amphtml"> (posts FR uniquement) */
  ampUrl?: string;
  /** Fil d'Ariane (passé directement au composant Breadcrumb) */
  breadcrumbs?: BreadcrumbItem[] | null;
  /** Afficher la navigation principale (default true) */
  showNav?: boolean;
  /** Afficher le fil d'Ariane (default true si breadcrumbs fournis) */
  showBreadcrumb?: boolean;
  /** Afficher le footer (default true) */
  showFooter?: boolean;
  /** Lien actif pour la navigation */
  activeHref?: string;
  /** Chemin canonique forcé (ex. /about.htm pour les routes legacy) */
  canonicalPath?: string;
}

const {
  title,
  description = '',
  lang = 'fr-CA',
  robots,
  image,
  imageAlt,
  type,
  ampUrl,
  breadcrumbs,
  showNav = true,
  showBreadcrumb = true,
  showFooter = true,
  activeHref,
  canonicalPath,
} = Astro.props;

const renderBreadcrumb = showBreadcrumb && breadcrumbs && breadcrumbs.length > 0;
const isEnPage = lang.startsWith('en');
const navLang = isEnPage ? 'en' : 'fr';
// Robots : directive best-practice par défaut (indexable + aperçus riches).
// Les pages /en/ restent `noindex` tant que enIndexable = false (contenu non traduit).
// Passer explicitement la prop `robots` sur une page pour forcer une valeur.
const defaultRobots =
  isEnPage && !siteConfig.enIndexable ? 'noindex, follow' : DEFAULT_ROBOTS;
const robotsContent = robots ?? defaultRobots;
const skipLabel = isEnPage ? 'Skip to main content' : 'Aller au contenu principal';
---
<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="preload"
      href="/fonts/schibsted-grotesk-normal-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/instrument-serif-normal-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {description && <meta name="description" content={description} />}
    <meta name="robots" content={robotsContent} />
    <title>{title}</title>
    <SeoHead
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      canonicalPath={canonicalPath}
    />
    {ampUrl && <link rel="amphtml" href={ampUrl} />}
    <FaviconHead />
  </head>
  <body class="bg-white text-ink font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-brand focus:px-4 focus:py-2 focus:text-white"
    >
      {skipLabel}
    </a>
    {showNav && (
      <HomeNavigation
        lang={navLang}
        activeHref={activeHref}
        switchPath={canonicalPath ?? Astro.url.pathname}
      />
    )}
    {renderBreadcrumb && <Breadcrumb items={breadcrumbs} lang={navLang} />}
    <div id="main-content">
      <slot />
    </div>
    {showFooter && <HomeFooter lang={navLang} />}
  </body>
</html>
