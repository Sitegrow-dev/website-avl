---
import { getHomeContent } from '@/data/home';
import Container from '@components/ui/Container.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import TextLink from '@components/ui/TextLink.astro';
import FigmaIcon from '@components/ui/FigmaIcon.astro';
import { localizedHref, resolveLang } from '@/lib/i18n';

const lang = resolveLang(Astro.currentLocale, Astro.url.pathname);
const { steps } = getHomeContent(lang);
---
<section class="py-24 lg:py-28" id="processus">
  <Container>
    <SectionHeader eyebrow={steps.eyebrow} title={steps.title} />
    <div class="mt-16 grid gap-8 sm:grid-cols-2 xl:grid-cols-4">
      {steps.items.map((item) => (
        <article class="rounded-sm border border-border bg-bg-card p-6">
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold text-brand">{item.step}</span>
            <FigmaIcon name={item.icon} size={32} />
          </div>
          <h3 class="mt-8 text-xl font-semibold text-ink">{item.title}</h3>
          <p class="mt-3 text-muted">{item.description}</p>
        </article>
      ))}
    </div>
    <div class="mt-12 text-center">
      <TextLink href={localizedHref(steps.link.href, lang)}>{steps.link.label}</TextLink>
    </div>
  </Container>
</section>
