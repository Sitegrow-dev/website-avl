---
import { homeContent } from '@/data/home';
import Container from '@components/ui/Container.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import TextLink from '@components/ui/TextLink.astro';

const { steps } = homeContent;

const icons: Record<string, string> = {
  'file-check': '<path d="M14 2H6a2 2 0 0 0-2 2v16l4-2 4 2 4-2 4 2V8l-6-6Z"/><path d="m9 15 2 2 4-4" stroke="currentColor" fill="none" stroke-width="2"/>',
  'map-pin': '<path d="M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  plane: '<path d="M2 12h5l3 7 4-14 3 7h5"/>',
  sparkles: '<path d="m12 3 1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3Z"/>',
};
---
<section class="py-24 lg:py-28" id="processus">
  <Container>
    <SectionHeader eyebrow={steps.eyebrow} title={steps.title} />
    <div class="mt-16 grid gap-8 sm:grid-cols-2 xl:grid-cols-4">
      {steps.items.map((item) => (
        <article class="rounded-sm border border-border bg-bg-card p-6">
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold text-brand">{item.step}</span>
            <svg class="h-8 w-8 text-brand" viewBox="0 0 24 24" fill="currentColor" set:html={icons[item.icon]} />
          </div>
          <h3 class="mt-8 text-xl font-semibold text-ink">{item.title}</h3>
          <p class="mt-3 text-muted">{item.description}</p>
        </article>
      ))}
    </div>
    <div class="mt-12 text-center">
      <TextLink href={steps.link.href}>{steps.link.label}</TextLink>
    </div>
  </Container>
</section>
