---
import { homeContent } from '@/data/home';
import { getPublishedPosts } from '@/data/posts';
import Container from '@components/ui/Container.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import TextLink from '@components/ui/TextLink.astro';
import { getPostHref } from '@/data/posts';

const { blog } = homeContent;
const posts = getPublishedPosts().slice(0, 3);
---
<section class="py-24 lg:py-28">
  <Container>
    <SectionHeader eyebrow={blog.eyebrow} title={blog.title} />
    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {posts.map((post) => (
        <article class="group">
          {post.image && (
            <a href={getPostHref(post)} class="block overflow-hidden rounded-sm">
              <ResponsiveImage
                src={post.image}
                alt={post.imageAlt ?? post.title}
                width={405}
                height={260}
                class="aspect-[405/260] w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            </a>
          )}
          <div class="mt-6">
            <p class="text-xs font-semibold uppercase tracking-wider text-brand">{post.category}</p>
            <h3 class="mt-3 font-display text-2xl leading-snug text-ink">
              <a href={getPostHref(post)} class="hover:text-brand">{post.title}</a>
            </h3>
            <TextLink href={getPostHref(post)} class="mt-4 inline-block">Lire →</TextLink>
          </div>
        </article>
      ))}
    </div>
  </Container>
</section>
