---
import { getHomeContent } from '@/data/home';
import Container from '@components/ui/Container.astro';
import Button from '@components/ui/Button.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import { localizedHref, resolveLang } from '@/lib/i18n';

const lang = resolveLang(Astro.currentLocale, Astro.url.pathname);
const { hero } = getHomeContent(lang);
---
<section class="relative flex min-h-[600px] items-center lg:min-h-[800px]">
  <div class="absolute inset-0">
    <ResponsiveImage
      src={hero.image}
      alt={hero.imageAlt}
      width={1600}
      height={900}
      loading="eager"
      fetchpriority="high"
      sizes="100vw"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/45" aria-hidden="true"></div>
  </div>
  <Container class="relative py-24 lg:py-32">
    <div class="max-w-2xl text-white">
      <h1 class="font-display text-5xl leading-none lg:text-[80px]">{hero.title}</h1>
      <p class="mt-4 text-xl leading-relaxed opacity-90 lg:text-2xl">{hero.subtitle}</p>
      <div class="mt-10">
        <Button href={localizedHref(hero.primaryCta.href, lang)} variant="primary">{hero.primaryCta.label}</Button>
      </div>
    </div>
  </Container>
</section>
