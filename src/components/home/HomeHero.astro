---
import { homeContent } from '@/data/home';
import Container from '@components/ui/Container.astro';
import Button from '@components/ui/Button.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';

const { hero } = homeContent;
---
<section class="relative flex min-h-[600px] items-center lg:min-h-[800px]">
  <div class="absolute inset-0">
    <ResponsiveImage
      src={hero.image}
      alt={hero.imageAlt}
      width={1600}
      height={900}
      loading="eager"
      fetchpriority="high"
      sizes="100vw"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/45" aria-hidden="true"></div>
  </div>
  <Container class="relative py-24 lg:py-32">
    <div class="max-w-2xl text-white">
      <h1 class="font-display text-5xl leading-none lg:text-[80px]">{hero.title}</h1>
      <p class="mt-4 text-xl leading-relaxed opacity-90 lg:text-2xl">{hero.subtitle}</p>
      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <Button href={hero.primaryCta.href} variant="primary">{hero.primaryCta.label}</Button>
        <Button href={hero.secondaryCta.href} variant="outline-white">{hero.secondaryCta.label}</Button>
      </div>
    </div>
  </Container>
</section>
