---
import { homeContent } from '@/data/home';
import Container from '@components/ui/Container.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import FigmaIcon from '@components/ui/FigmaIcon.astro';

const { testimonials } = homeContent;
---
<section class="bg-bg-alt py-24 lg:py-28">
  <Container>
    <SectionHeader eyebrow={testimonials.eyebrow} title={testimonials.title} />
    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {testimonials.items.map((item) => (
        <blockquote class="rounded-sm border border-border bg-white p-10">
          <FigmaIcon name="text-quote" width={32} height={24} />
          <p class="mt-8 text-lg leading-relaxed text-ink">{item.quote}</p>
          <footer class="mt-10">
            <p class="font-semibold text-ink">{item.name}</p>
            <p class="text-sm text-muted">{item.location}</p>
          </footer>
        </blockquote>
      ))}
    </div>
  </Container>
</section>
