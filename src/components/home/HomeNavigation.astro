---
import SiteLogo from '@components/home/SiteLogo.astro';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import { getNavigation, type NavLink } from '@/data/navigation';
import { localizedHref, type Lang } from '@/lib/i18n';

interface Props {
  activeHref?: string;
  lang?: Lang;
  /** Chemin public pour le sélecteur de langue (ex. /about.htm). */
  switchPath?: string;
}

const { activeHref, lang = 'fr', switchPath } = Astro.props;
const { nav, navCta } = getNavigation(lang);
const menuLabel = lang === 'en' ? 'Open menu' : 'Ouvrir le menu';
const closeLabel = lang === 'en' ? 'Close menu' : 'Fermer le menu';
const navLabel = lang === 'en' ? 'Main navigation' : 'Navigation principale';
const homeHref = localizedHref('/', lang);

function isActive(href: string) {
  const localized = localizedHref(href, lang);
  if (!activeHref) return false;
  if (href.startsWith('/#')) return activeHref === href || activeHref === localized;
  return (
    activeHref === localized ||
    activeHref === href ||
    (localized !== '/' && activeHref.startsWith(localized))
  );
}

function isGroupActive(link: NavLink) {
  if (isActive(link.href)) return true;
  return link.children?.some((child) => isActive(child.href)) ?? false;
}
---
<header class="sticky top-0 z-50 border-b border-black/5 bg-white/95 backdrop-blur-md">
  <div class="relative z-[110] mx-auto flex h-[84px] max-w-[1440px] items-center justify-between gap-6 px-5 lg:px-20">
    <SiteLogo variant="dark" height={58} href={homeHref} />

    <nav class="hidden items-center gap-6 xl:flex" aria-label={navLabel}>
      {nav.map((link) =>
        link.children?.length ? (
          <div class="nav-dropdown group relative">
            <a
              href={localizedHref(link.href, lang)}
              class:list={[
                'inline-flex items-center gap-1.5 text-[15px] font-medium transition-colors',
                isGroupActive(link) ? 'text-brand' : 'text-ink/80 hover:text-ink',
              ]}
              aria-haspopup="true"
            >
              {link.label}
              <svg
                class="h-3.5 w-3.5 opacity-70 transition-transform group-hover:rotate-180 group-focus-within:rotate-180"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                  clip-rule="evenodd"
                ></path>
              </svg>
            </a>
            {isGroupActive(link) && (
              <span class="absolute -bottom-[31px] left-0 h-0.5 w-5 bg-brand" aria-hidden="true"
              ></span>
            )}
            {link.variant === 'mega' ? (
              <div
                class="invisible absolute left-1/2 top-full z-50 w-[min(52rem,calc(100vw-2rem))] -translate-x-1/2 pt-3 opacity-0 transition-[opacity,visibility] duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
              >
                <div
                  class="rounded-md border border-black/[0.08] bg-white p-4 shadow-[0_16px_48px_-16px_rgba(0,0,0,0.2)]"
                >
                  <ul class="grid grid-cols-2 gap-1 sm:grid-cols-3" role="list">
                    {link.children.map((child, index) => (
                      <li class:list={[index === 0 && 'col-span-2 sm:col-span-3']}>
                        <a
                          href={localizedHref(child.href, lang)}
                          class:list={[
                            'block rounded-md px-3 py-3 transition-colors',
                            isActive(child.href)
                              ? 'bg-brand/5'
                              : 'hover:bg-black/[0.03]',
                            index === 0 && 'border border-black/[0.06] bg-stone-50/80',
                          ]}
                        >
                          <span
                            class:list={[
                              'block text-sm font-semibold',
                              isActive(child.href) ? 'text-brand' : 'text-ink',
                            ]}
                          >
                            {child.label}
                          </span>
                          {child.description && (
                            <span class="mt-0.5 block text-xs leading-snug text-muted">
                              {child.description}
                            </span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ) : (
              <div
                class="invisible absolute left-0 top-full z-50 min-w-[18rem] pt-4 opacity-0 transition-[opacity,visibility] duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
              >
                <ul
                  class="rounded-md border border-black/[0.08] bg-white py-2 shadow-[0_12px_40px_-12px_rgba(0,0,0,0.18)]"
                  role="list"
                >
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={localizedHref(child.href, lang)}
                        class:list={[
                          'block px-4 py-2.5 text-sm transition-colors',
                          isActive(child.href)
                            ? 'bg-brand/5 font-semibold text-brand'
                            : 'text-ink/80 hover:bg-black/[0.03] hover:text-ink',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ) : (
          <a
            href={localizedHref(link.href, lang)}
            class:list={[
              'relative text-[15px] font-medium transition-colors',
              isActive(link.href) ? 'text-brand' : 'text-ink/80 hover:text-ink',
            ]}
          >
            {link.label}
            {isActive(link.href) && (
              <span class="absolute -bottom-[31px] left-0 h-0.5 w-5 bg-brand" aria-hidden="true"
              ></span>
            )}
          </a>
        ),
      )}
    </nav>

    <div class="flex items-center gap-3">
      <LanguageSwitcher lang={lang} path={switchPath} class="hidden xl:flex" />
      <a
        href={localizedHref(navCta.href, lang)}
        class="hidden rounded-sm bg-brand px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition-colors hover:bg-brand-hover xl:inline-flex"
      >
        {navCta.label}
      </a>

      <button
        type="button"
        id="home-mobile-menu-btn"
        class="relative flex h-10 w-10 flex-col items-center justify-center gap-1.5 xl:hidden"
        aria-label={menuLabel}
        aria-expanded="false"
        aria-controls="home-mobile-menu"
      >
        <span class="home-menu-line block h-0.5 w-5 bg-ink transition-all"></span>
        <span class="home-menu-line block h-0.5 w-5 bg-ink transition-all"></span>
        <span class="home-menu-line block h-0.5 w-5 bg-ink transition-all"></span>
      </button>
    </div>
  </div>
</header>

<div
  id="home-mobile-menu"
  class="fixed inset-0 z-[100] hidden flex-col items-center justify-center gap-8 overflow-y-auto bg-white/95 px-6 py-20 opacity-0 backdrop-blur-lg transition-opacity duration-300 xl:hidden"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label={navLabel}
>
  <button
    type="button"
    id="home-mobile-menu-close"
    class="absolute right-5 top-6 flex h-10 w-10 items-center justify-center text-ink"
    aria-label={closeLabel}
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
  <SiteLogo variant="dark" height={64} class="mb-2" href={homeHref} />
  <nav class="flex w-full max-w-sm flex-col items-stretch gap-4" aria-label={lang === 'en' ? 'Mobile navigation' : 'Navigation mobile'}>
    {nav.map((link) =>
      link.children?.length ? (
        <div class="border-b border-black/[0.06] pb-4">
          <a
            href={localizedHref(link.href, lang)}
            class="block text-center text-xl font-semibold text-ink"
          >
            {link.label}
          </a>
          <ul class="mt-3 space-y-2.5 text-center">
            {link.children.map((child) => (
              <li>
                <a
                  href={localizedHref(child.href, lang)}
                  class="block text-base text-muted transition-colors hover:text-ink"
                >
                  {child.label}
                  {link.variant === 'mega' && child.description && (
                    <span class="mt-0.5 block text-xs leading-snug text-muted/80">
                      {child.description}
                    </span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ) : (
        <a href={localizedHref(link.href, lang)} class="text-center text-xl font-semibold text-ink">
          {link.label}
        </a>
      ),
    )}
  </nav>
  <LanguageSwitcher lang={lang} path={switchPath} class="justify-center" />
  <a href={localizedHref(navCta.href, lang)} class="rounded-sm bg-brand px-6 py-3 text-sm font-semibold uppercase text-white">
    {navCta.label}
  </a>
</div>

<style>
  #home-mobile-menu-btn[aria-expanded='true'] .home-menu-line:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }
  #home-mobile-menu-btn[aria-expanded='true'] .home-menu-line:nth-child(2) {
    opacity: 0;
  }
  #home-mobile-menu-btn[aria-expanded='true'] .home-menu-line:nth-child(3) {
    transform: translateY(-4px) rotate(-45deg);
  }
</style>

<script>
  function initHomeMobileMenu() {
    const btnEl = document.getElementById('home-mobile-menu-btn');
    const menuEl = document.getElementById('home-mobile-menu');
    if (!btnEl || !menuEl) return;
    const btn: HTMLElement = btnEl;
    const menu: HTMLElement = menuEl;
    if (btn.dataset.menuInit === 'true') return;
    btn.dataset.menuInit = 'true';

    const openLabel = btn.getAttribute('aria-label') ?? 'Ouvrir le menu';
    const closeLabel = document.getElementById('home-mobile-menu-close')?.getAttribute('aria-label') ?? 'Fermer le menu';

    function closeMenu() {
      menu.classList.remove('opacity-100', 'pointer-events-auto');
      menu.classList.add('opacity-0', 'pointer-events-none');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', openLabel);
      menu.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('overflow-hidden');
      const onEnd = () => {
        if (menu.classList.contains('opacity-0')) {
          menu.classList.remove('flex');
          menu.classList.add('hidden');
        }
      };
      menu.addEventListener('transitionend', onEnd, { once: true });
    }

    function openMenu() {
      menu.classList.remove('hidden', 'opacity-0', 'pointer-events-none');
      menu.classList.add('flex', 'pointer-events-auto');
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', closeLabel);
      menu.setAttribute('aria-hidden', 'false');
      document.body.classList.add('overflow-hidden');
      requestAnimationFrame(() => menu.classList.add('opacity-100'));
    }

    btn.onclick = () => {
      if (btn.getAttribute('aria-expanded') === 'true') closeMenu();
      else openMenu();
    };
    document.getElementById('home-mobile-menu-close')?.addEventListener('click', closeMenu);
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') closeMenu();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomeMobileMenu);
  } else {
    initHomeMobileMenu();
  }
  document.addEventListener('astro:page-load', initHomeMobileMenu);
</script>
