---
import SiteLogo from '@components/home/SiteLogo.astro';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import SearchForm from '@components/SearchForm.astro';
import { getNavigation, type NavLink } from '@/data/navigation';
import { getSearchContent } from '@/data/search';
import { localizedHref, type Lang } from '@/lib/i18n';

interface Props {
  activeHref?: string;
  lang?: Lang;
  /** Chemin public pour le sélecteur de langue (ex. /about.htm). */
  switchPath?: string;
}

const { activeHref, lang = 'fr', switchPath } = Astro.props;
const { nav, navCta } = getNavigation(lang);
const searchCopy = getSearchContent(lang);
const menuLabel = lang === 'en' ? 'Open menu' : 'Ouvrir le menu';
const closeLabel = lang === 'en' ? 'Close menu' : 'Fermer le menu';
const navLabel = lang === 'en' ? 'Main navigation' : 'Navigation principale';
const homeHref = localizedHref('/', lang);
const expandLabel = lang === 'en' ? 'Show submenu' : 'Afficher le sous-menu';
const collapseLabel = lang === 'en' ? 'Hide submenu' : 'Masquer le sous-menu';

function isActive(href: string) {
  const localized = localizedHref(href, lang);
  if (!activeHref) return false;
  if (href.startsWith('/#')) return activeHref === href || activeHref === localized;
  return (
    activeHref === localized ||
    activeHref === href ||
    (localized !== '/' && activeHref.startsWith(localized))
  );
}

function isGroupActive(link: NavLink) {
  if (isActive(link.href)) return true;
  return link.children?.some((child) => isActive(child.href)) ?? false;
}
---
<header class="sticky top-0 z-50 border-b border-black/5 bg-white/95 backdrop-blur-md">
  <div class="relative z-[110] mx-auto flex h-[84px] max-w-[1440px] items-center justify-between gap-6 px-5 lg:px-20">
    <SiteLogo variant="dark" height={58} href={homeHref} />

    <nav class="hidden items-center gap-6 xl:flex" aria-label={navLabel}>
      {nav.map((link) =>
        link.children?.length ? (
          <div class="nav-dropdown group relative">
            <a
              href={localizedHref(link.href, lang)}
              class:list={[
                'inline-flex items-center gap-1.5 text-[15px] font-medium transition-colors',
                isGroupActive(link) ? 'text-brand' : 'text-ink/80 hover:text-ink',
              ]}
              aria-haspopup="true"
            >
              {link.label}
              <svg
                class="h-3.5 w-3.5 opacity-70 transition-transform group-hover:rotate-180 group-focus-within:rotate-180"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                  clip-rule="evenodd"
                ></path>
              </svg>
            </a>
            {isGroupActive(link) && (
              <span class="absolute -bottom-[31px] left-0 h-0.5 w-5 bg-brand" aria-hidden="true"
              ></span>
            )}
            {link.variant === 'mega' ? (
              <div
                class="invisible absolute left-1/2 top-full z-50 w-[min(52rem,calc(100vw-2rem))] -translate-x-1/2 pt-3 opacity-0 transition-[opacity,visibility] duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
              >
                <div
                  class="rounded-md border border-black/[0.08] bg-white p-4 shadow-[0_16px_48px_-16px_rgba(0,0,0,0.2)]"
                >
                  <ul class="grid grid-cols-2 gap-1 sm:grid-cols-3" role="list">
                    {link.children.map((child, index) => (
                      <li class:list={[index === 0 && 'col-span-2 sm:col-span-3']}>
                        <a
                          href={localizedHref(child.href, lang)}
                          class:list={[
                            'block rounded-md px-3 py-3 transition-colors',
                            isActive(child.href)
                              ? 'bg-brand/5'
                              : 'hover:bg-black/[0.03]',
                            index === 0 && 'border border-black/[0.06] bg-stone-50/80',
                          ]}
                        >
                          <span
                            class:list={[
                              'block text-sm font-semibold',
                              isActive(child.href) ? 'text-brand' : 'text-ink',
                            ]}
                          >
                            {child.label}
                          </span>
                          {child.description && (
                            <span class="mt-0.5 block text-xs leading-snug text-muted">
                              {child.description}
                            </span>
                          )}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ) : (
              <div
                class="invisible absolute left-0 top-full z-50 min-w-[18rem] pt-4 opacity-0 transition-[opacity,visibility] duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
              >
                <ul
                  class="rounded-md border border-black/[0.08] bg-white py-2 shadow-[0_12px_40px_-12px_rgba(0,0,0,0.18)]"
                  role="list"
                >
                  {link.children.map((child) => (
                    <li>
                      <a
                        href={localizedHref(child.href, lang)}
                        class:list={[
                          'block px-4 py-2.5 text-sm transition-colors',
                          isActive(child.href)
                            ? 'bg-brand/5 font-semibold text-brand'
                            : 'text-ink/80 hover:bg-black/[0.03] hover:text-ink',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ) : (
          <a
            href={localizedHref(link.href, lang)}
            class:list={[
              'relative text-[15px] font-medium transition-colors',
              isActive(link.href) ? 'text-brand' : 'text-ink/80 hover:text-ink',
            ]}
          >
            {link.label}
            {isActive(link.href) && (
              <span class="absolute -bottom-[31px] left-0 h-0.5 w-5 bg-brand" aria-hidden="true"
              ></span>
            )}
          </a>
        ),
      )}
    </nav>

    <div class="flex items-center gap-3">
      <SearchForm lang={lang} variant="header" />
      <a
        href={searchCopy.path}
        class="flex h-11 w-11 items-center justify-center text-ink/70 transition-colors hover:text-ink xl:hidden"
        aria-label={searchCopy.openLabel}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M20 20l-3.5-3.5"></path>
        </svg>
      </a>
      <LanguageSwitcher lang={lang} path={switchPath} class="hidden xl:flex" />
      <a
        href={localizedHref(navCta.href, lang)}
        class="hidden rounded-sm bg-brand px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition-colors hover:bg-brand-hover xl:inline-flex"
      >
        {navCta.label}
      </a>

      <button
        type="button"
        id="home-mobile-menu-btn"
        class="relative flex h-11 w-11 flex-col items-center justify-center gap-1.5 xl:hidden"
        aria-label={menuLabel}
        aria-expanded="false"
        aria-controls="home-mobile-menu"
        data-close-label={closeLabel}
      >
        <span class="home-menu-line block h-0.5 w-5 bg-ink transition-all duration-200"></span>
        <span class="home-menu-line block h-0.5 w-5 bg-ink transition-all duration-200"></span>
        <span class="home-menu-line block h-0.5 w-5 bg-ink transition-all duration-200"></span>
      </button>
    </div>
  </div>
</header>

<div
  id="home-mobile-menu"
  class="fixed inset-x-0 bottom-0 top-[84px] z-[90] hidden flex-col border-t border-black/[0.06] bg-white opacity-0 shadow-[0_-8px_32px_-16px_rgba(0,0,0,0.12)] transition-opacity duration-300 xl:hidden"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label={navLabel}
  data-expand-label={expandLabel}
  data-collapse-label={collapseLabel}
>
  <nav
    class="min-h-0 flex-1 overflow-y-auto overscroll-contain px-5 py-2"
    aria-label={lang === 'en' ? 'Mobile navigation' : 'Navigation mobile'}
  >
    <ul class="divide-y divide-black/[0.06]" role="list">
      {nav.map((link) =>
        link.children?.length ? (
          <li class="mobile-nav-group" data-open={isGroupActive(link) ? 'true' : 'false'}>
            <div class="flex items-stretch">
              <a
                href={localizedHref(link.href, lang)}
                class:list={[
                  'flex min-h-12 flex-1 items-center py-3 pr-2 text-[15px] font-semibold leading-snug',
                  isGroupActive(link) ? 'text-brand' : 'text-ink',
                ]}
              >
                {link.label}
              </a>
              <button
                type="button"
                class="mobile-nav-toggle flex h-12 w-12 shrink-0 items-center justify-center text-ink/60"
                aria-expanded={isGroupActive(link) ? 'true' : 'false'}
                aria-label={isGroupActive(link) ? collapseLabel : expandLabel}
              >
                <svg
                  class="mobile-nav-chevron h-4 w-4 transition-transform duration-200"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.17l3.71-3.94a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                    clip-rule="evenodd"
                  ></path>
                </svg>
              </button>
            </div>
            <ul
              class:list={[
                'mobile-nav-submenu space-y-0.5 pb-3 pl-1',
                !isGroupActive(link) && 'hidden',
              ]}
              role="list"
            >
              {link.children.map((child) => (
                <li>
                  <a
                    href={localizedHref(child.href, lang)}
                    class:list={[
                      'flex min-h-11 items-center rounded-md px-3 py-2.5 text-[15px] leading-snug transition-colors',
                      isActive(child.href)
                        ? 'bg-brand/5 font-semibold text-brand'
                        : 'text-ink/70 hover:bg-black/[0.03] hover:text-ink',
                    ]}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ) : (
          <li>
            <a
              href={localizedHref(link.href, lang)}
              class:list={[
                'flex min-h-12 items-center py-3 text-[15px] font-semibold',
                isActive(link.href) ? 'text-brand' : 'text-ink',
              ]}
            >
              {link.label}
            </a>
          </li>
        ),
      )}
    </ul>
  </nav>

  <div class="shrink-0 space-y-3 border-t border-black/[0.06] bg-white px-5 pb-[max(1.5rem,env(safe-area-inset-bottom))] pt-4">
    <SearchForm lang={lang} variant="mobile" />
    <LanguageSwitcher lang={lang} path={switchPath} />
    <a
      href={localizedHref(navCta.href, lang)}
      class="flex min-h-12 w-full items-center justify-center rounded-sm bg-brand px-6 text-sm font-semibold uppercase tracking-wide text-white transition-colors hover:bg-brand-hover"
    >
      {navCta.label}
    </a>
  </div>
</div>

<style>
  #home-mobile-menu-btn[aria-expanded='true'] .home-menu-line:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  #home-mobile-menu-btn[aria-expanded='true'] .home-menu-line:nth-child(2) {
    opacity: 0;
  }
  #home-mobile-menu-btn[aria-expanded='true'] .home-menu-line:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .mobile-nav-group[data-open='true'] .mobile-nav-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  function initHomeMobileMenu() {
    const btnEl = document.getElementById('home-mobile-menu-btn');
    const menuEl = document.getElementById('home-mobile-menu');
    if (!btnEl || !menuEl) return;
    const btn: HTMLElement = btnEl;
    const menu: HTMLElement = menuEl;
    if (btn.dataset.menuInit === 'true') return;
    btn.dataset.menuInit = 'true';

    const openLabel = btn.getAttribute('aria-label') ?? 'Ouvrir le menu';
    const closeLabel = btn.dataset.closeLabel ?? 'Fermer le menu';
    const expandLabel = menu.dataset.expandLabel ?? 'Afficher le sous-menu';
    const collapseLabel = menu.dataset.collapseLabel ?? 'Masquer le sous-menu';

    function closeMenu() {
      menu.classList.remove('opacity-100', 'pointer-events-auto');
      menu.classList.add('opacity-0', 'pointer-events-none');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', openLabel);
      menu.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('overflow-hidden');
      const onEnd = () => {
        if (menu.classList.contains('opacity-0')) {
          menu.classList.remove('flex');
          menu.classList.add('hidden');
        }
      };
      menu.addEventListener('transitionend', onEnd, { once: true });
    }

    function openMenu() {
      menu.classList.remove('hidden', 'opacity-0', 'pointer-events-none');
      menu.classList.add('flex', 'pointer-events-auto');
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', closeLabel);
      menu.setAttribute('aria-hidden', 'false');
      document.body.classList.add('overflow-hidden');
      requestAnimationFrame(() => menu.classList.add('opacity-100'));
    }

    btn.onclick = () => {
      if (btn.getAttribute('aria-expanded') === 'true') closeMenu();
      else openMenu();
    };
    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));

    menu.querySelectorAll('.mobile-nav-toggle').forEach((toggleEl) => {
      const toggle = toggleEl as HTMLButtonElement;
      toggle.addEventListener('click', () => {
        const group = toggle.closest('.mobile-nav-group') as HTMLElement | null;
        const submenu = group?.querySelector('.mobile-nav-submenu') as HTMLElement | null;
        if (!group || !submenu) return;
        const willOpen = group.dataset.open !== 'true';

        menu.querySelectorAll('.mobile-nav-group').forEach((otherEl) => {
          const other = otherEl as HTMLElement;
          if (other === group) return;
          other.dataset.open = 'false';
          const otherToggle = other.querySelector('.mobile-nav-toggle') as HTMLButtonElement | null;
          const otherSub = other.querySelector('.mobile-nav-submenu') as HTMLElement | null;
          otherToggle?.setAttribute('aria-expanded', 'false');
          otherToggle?.setAttribute('aria-label', expandLabel);
          otherSub?.classList.add('hidden');
        });

        group.dataset.open = willOpen ? 'true' : 'false';
        toggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        toggle.setAttribute('aria-label', willOpen ? collapseLabel : expandLabel);
        submenu.classList.toggle('hidden', !willOpen);
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') closeMenu();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomeMobileMenu);
  } else {
    initHomeMobileMenu();
  }
  document.addEventListener('astro:page-load', initHomeMobileMenu);
</script>
