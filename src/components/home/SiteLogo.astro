---
import { siteConfig } from '@/config/site';

interface Props {
  class?: string;
  height?: number;
}

const { class: className = '' } = Astro.props;
---
<a href="/" class:list={['inline-flex shrink-0 items-center', className]} aria-label={siteConfig.siteName}>
  <span class="font-display text-xl text-ink lg:text-[26px]">{siteConfig.siteName}</span>
</a>
