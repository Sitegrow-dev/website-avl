---
import { getHomeContent } from '@/data/home';
import Container from '@components/ui/Container.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import { localizedHref, resolveLang } from '@/lib/i18n';

const lang = resolveLang(Astro.currentLocale, Astro.url.pathname);
const { destinations } = getHomeContent(lang);
const featured = destinations.items.find((d) => 'featured' in d && d.featured)!;
const [rome, ...bottomRow] = destinations.items.filter((d) => !('featured' in d && d.featured));
---
<section class="py-24 lg:py-28">
  <Container>
    <SectionHeader title={destinations.title} />
    <div class="mt-16 grid gap-8 lg:grid-cols-12">
      <a href={localizedHref(featured.href, lang)} class="group relative overflow-hidden rounded-sm lg:col-span-7 lg:row-span-2">
        <ResponsiveImage
          src={featured.image}
          alt={featured.title}
          width={843}
          height={600}
          class="h-full min-h-[280px] w-full object-cover transition-transform duration-500 group-hover:scale-105 lg:min-h-[600px]"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-8 text-white">
          <h3 class="font-display text-2xl lg:text-3xl">{featured.title}</h3>
        </div>
      </a>
      {rome && (
        <a href={localizedHref(rome.href, lang)} class="group relative overflow-hidden rounded-sm lg:col-span-5">
          <ResponsiveImage
            src={rome.image}
            alt={rome.title}
            width={405}
            height={284}
            class="h-full min-h-[200px] w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6 text-white lg:p-8">
            <h3 class="font-display text-2xl">{rome.title}</h3>
          </div>
        </a>
      )}
      {bottomRow.map((item) => (
        <a href={localizedHref(item.href, lang)} class="group relative overflow-hidden rounded-sm lg:col-span-4">
          <ResponsiveImage
            src={item.image}
            alt={item.title}
            width={405}
            height={284}
            class="h-full min-h-[200px] w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6 text-white lg:p-8">
            <h3 class="font-display text-2xl">{item.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
