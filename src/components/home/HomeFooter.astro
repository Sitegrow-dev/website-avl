---
import { siteConfig } from '@/config/site';
import { getNavigation } from '@/data/navigation';
import Container from '@components/ui/Container.astro';
import SiteLogo from '@components/home/SiteLogo.astro';
import { localizedHref, type Lang } from '@/lib/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const { footer, nav, navCta } = getNavigation(lang);
const { siteName, phone, social } = siteConfig;
const year = new Date().getFullYear();
const homeHref = localizedHref('/', lang);

/** Liens nav principaux + CTA, dédupliqués (ordre conservé). */
const footerLinks = [
  { label: lang === 'en' ? 'Home' : 'Accueil', href: '/' },
  ...nav,
  navCta,
].filter(
  (link, index, arr) => arr.findIndex((l) => l.href === link.href) === index,
);

const socialLinks = [
  { label: 'Instagram', href: social.instagram },
  { label: 'Facebook', href: social.facebook },
  { label: 'LinkedIn', href: social.linkedin },
  { label: 'YouTube', href: social.youtube },
  { label: 'X', href: social.x },
].filter((l) => l.href);

const linkClass = 'whitespace-nowrap text-sm text-muted transition-colors hover:text-ink';
---
<footer class="border-t border-border bg-white py-5 lg:py-6">
  <Container>
    <div
      class="flex items-center justify-between gap-x-4 sm:gap-x-6 lg:gap-x-8 max-sm:flex-wrap max-sm:justify-center max-sm:gap-y-3"
    >
      <SiteLogo class="shrink-0" variant="dark" height={40} href={homeHref} />

      <nav aria-label={lang === 'en' ? 'Footer' : 'Pied de page'} class="min-w-0">
        <ul class="flex flex-nowrap items-center justify-center gap-x-4 sm:gap-x-5 max-sm:flex-wrap max-sm:gap-y-2">
          {footerLinks.map((link) => (
            <li>
              <a href={localizedHref(link.href, lang)} class={linkClass}>
                {link.label}
              </a>
            </li>
          ))}
          {phone && (
            <li>
              <span class="whitespace-nowrap text-sm text-muted">{phone}</span>
            </li>
          )}
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class={linkClass}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div
        class="flex shrink-0 flex-nowrap items-center justify-end gap-x-4 sm:gap-x-5 text-sm text-muted max-sm:flex-wrap max-sm:justify-center max-sm:gap-y-2"
      >
        <p class="whitespace-nowrap">
          &copy; {year}{' '}
          <a
            href={homeHref}
            class="transition-colors hover:text-ink"
            aria-label={siteName}
          >
            {siteName}
          </a>
          . {footer.rights}
        </p>
        {footer.legal.links.map((link) => (
          <a href={localizedHref(link.href, lang)} class={linkClass}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </Container>
</footer>
