---
import { siteConfig } from '@/config/site';
import Container from '@components/ui/Container.astro';
import SiteLogo from '@components/home/SiteLogo.astro';

const { footer, siteName } = siteConfig;
const year = new Date().getFullYear();
---
<footer class="border-t border-border bg-white pb-10 pt-20 lg:pt-24">
  <Container>
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <SiteLogo variant="dark" height={88} />
        <p class="mt-6 max-w-xs text-[15px] leading-6 text-muted">{footer.tagline}</p>
      </div>

      {footer.columns.map((column) => (
        <div>
          <p class="text-[15px] font-semibold text-ink">{column.title}</p>
          <ul class="mt-6 flex flex-col gap-4">
            {column.links.map((link) => (
              <li>
                <a href={link.href} class="text-[15px] text-muted transition-colors hover:text-ink">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 border-t border-border pt-10">
      <p class="text-sm text-muted">
        &copy; {year} {siteName}. Tous droits réservés.
      </p>
    </div>
  </Container>
</footer>
