---
import { siteConfig } from '@/config/site';
import { getNavigation } from '@/data/navigation';
import Container from '@components/ui/Container.astro';
import SiteLogo from '@components/home/SiteLogo.astro';
import { localizedHref, type Lang } from '@/lib/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const { footer } = getNavigation(lang);
const { siteName, contactEmail, phone, social } = siteConfig;
const year = new Date().getFullYear();
const homeHref = localizedHref('/', lang);

const contactTitle = lang === 'en' ? 'Contact' : 'Contact';
const followTitle = lang === 'en' ? 'Follow us' : 'Suivez-nous';

const socialLinks = [
  { label: 'Instagram', href: social.instagram },
  { label: 'Facebook', href: social.facebook },
  { label: 'LinkedIn', href: social.linkedin },
  { label: 'YouTube', href: social.youtube },
  { label: 'X', href: social.x },
].filter((l) => l.href);
---
<footer class="border-t border-border bg-white pb-10 pt-20 lg:pt-24">
  <Container>
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <SiteLogo variant="dark" height={88} href={homeHref} />
        <p class="mt-6 max-w-xs text-[15px] leading-6 text-muted">{footer.tagline}</p>
      </div>

      {footer.columns.map((column) => (
        <div>
          <p class="text-[15px] font-semibold text-ink">{column.title}</p>
          <ul class="mt-6 flex flex-col gap-4">
            {column.links.map((link) => (
              <li>
                <a
                  href={localizedHref(link.href, lang)}
                  class="text-[15px] text-muted transition-colors hover:text-ink"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <p class="text-[15px] font-semibold text-ink">{contactTitle}</p>
        <ul class="mt-6 flex flex-col gap-3">
          {contactEmail && (
            <li>
              <a
                href={`mailto:${contactEmail}`}
                class="text-[15px] text-muted transition-colors hover:text-ink"
              >
                {contactEmail}
              </a>
            </li>
          )}
          {phone && (
            <li>
              <span class="text-[15px] text-muted">{phone}</span>
            </li>
          )}
        </ul>
        {socialLinks.length > 0 && (
          <>
            <p class="mt-6 text-[15px] font-semibold text-ink">{followTitle}</p>
            <ul class="mt-4 flex flex-col gap-3">
              {socialLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[15px] text-muted transition-colors hover:text-ink"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )}
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center gap-4 border-t border-border pt-10 sm:flex-row sm:justify-between">
      <p class="text-sm text-muted">
        &copy; {year}{' '}
        <a
          href={homeHref}
          class="transition-colors hover:text-ink"
          aria-label={siteName}
        >
          {siteName}
        </a>
        . {footer.rights}
      </p>
      <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2">
        {footer.legal.links.map((link) => (
          <li>
            <a
              href={localizedHref(link.href, lang)}
              class="text-sm text-muted transition-colors hover:text-ink"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </Container>
</footer>
