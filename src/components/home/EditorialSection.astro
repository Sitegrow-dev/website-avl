---
import { getHomeContent } from '@/data/home';
import Container from '@components/ui/Container.astro';
import TextLink from '@components/ui/TextLink.astro';
import { localizedHref, resolveLang } from '@/lib/i18n';

const lang = resolveLang(Astro.currentLocale, Astro.url.pathname);
const { editorial } = getHomeContent(lang);
---
<section class="bg-bg-alt py-24 lg:py-40">
  <Container>
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-display text-4xl leading-tight text-ink lg:text-[52px]">{editorial.title}</h2>
      <div class="mt-10 space-y-6 text-lg leading-relaxed text-muted">
        {editorial.paragraphs.map((p) => (
          <p>{p}</p>
        ))}
      </div>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-8">
        {editorial.links.map((link) => (
          <TextLink href={localizedHref(link.href, lang)}>{link.label}</TextLink>
        ))}
      </div>
    </div>
  </Container>
</section>
