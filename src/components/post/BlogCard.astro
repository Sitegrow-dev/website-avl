---
import type { Post } from '@/data/posts';
import { getPostHref } from '@/data/posts';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import TextLink from '@components/ui/TextLink.astro';
import { resolveImageAlt } from '@/lib/image-alt';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const href = getPostHref(post);

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---
<article
  data-category={post.categorySlug}
  class="overflow-hidden rounded-sm border border-border bg-white"
>
  {post.image && (
    <a href={href}>
      <ResponsiveImage
        src={post.image}
        alt={resolveImageAlt(post.imageAlt, post.title)}
        width={405}
        height={220}
        class="aspect-[405/220] w-full object-cover"
      />
    </a>
  )}
  <div class="p-6">
    <p class="text-xs font-semibold uppercase tracking-wider text-brand">{post.category}</p>
    <h3 class="mt-3 font-display text-2xl leading-snug text-ink">
      <a href={href} class="hover:text-brand">{post.title}</a>
    </h3>
    <p class="mt-3 text-muted">{post.summary}</p>
    <div class="mt-6 flex items-center justify-between">
      <span class="text-sm text-muted">{formatDate(post.date)}</span>
      <TextLink href={href}>Lire →</TextLink>
    </div>
  </div>
</article>
