---
import type { Post } from '@/data/posts';
import Container from '@components/ui/Container.astro';

interface Props {
  post: Post;
  lang?: 'fr' | 'en';
}

const { post, lang = 'fr' } = Astro.props;

function formatDate(date: string) {
  return new Date(date).toLocaleDateString(lang === 'en' ? 'en-CA' : 'fr-CA', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

const updatedLabel = lang === 'en' ? 'Updated' : 'Mis à jour le';
const readLabel = lang === 'en' ? 'min read' : 'min de lecture';
---
<section class="bg-bg-alt pb-12 pt-12 lg:pt-16">
  <Container>
    <div class="max-w-4xl">
      <span class="inline-block rounded-sm bg-brand-light px-4 py-2 text-xs font-semibold uppercase tracking-wider text-brand">
        {post.category}
      </span>
      <h1 class="mt-6 font-display text-4xl leading-tight text-ink lg:text-[70px] lg:leading-[1.1]">
        {post.title}
      </h1>
      <p class="mt-6 text-sm text-muted">
        {updatedLabel} {formatDate(post.updated ?? post.date)} · {post.readingTimeMinutes ?? 5} {readLabel}
      </p>
      {post.chapo && (
        <p class="mt-6 max-w-3xl text-xl leading-relaxed text-muted">{post.chapo}</p>
      )}
    </div>
  </Container>
</section>
