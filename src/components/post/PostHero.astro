---
import type { Post } from '@/data/posts';
import Container from '@components/ui/Container.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import { breadcrumbTrails } from '@/lib/breadcrumb';

interface Props {
  post: Post;
}

const { post } = Astro.props;

function formatDate(date: string) {
  return new Date(date).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

const crumbs = [
  ...breadcrumbTrails.blog('fr'),
  { label: post.category, href: `/blog/?cat=${post.categorySlug}` },
];
---
<section class="bg-bg-alt pb-12 pt-28">
  <Container>
    <Breadcrumb items={crumbs} />
    <div class="mt-8 max-w-4xl">
      <span class="inline-block rounded-sm bg-brand-light px-4 py-2 text-xs font-semibold uppercase tracking-wider text-brand">
        {post.category}
      </span>
      <h1 class="mt-6 font-display text-4xl leading-tight text-ink lg:text-[70px] lg:leading-[1.1]">
        {post.title}
      </h1>
      <p class="mt-6 text-sm text-muted">
        Mis à jour le {formatDate(post.updated ?? post.date)} · {post.readingTimeMinutes ?? 5} min de lecture
      </p>
      {post.chapo && (
        <p class="mt-6 max-w-3xl text-xl leading-relaxed text-muted">{post.chapo}</p>
      )}
    </div>
  </Container>
</section>
