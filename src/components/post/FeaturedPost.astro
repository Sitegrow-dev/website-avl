---
import type { Post } from '@/data/posts';
import { getPostHref } from '@/data/posts';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import Button from '@components/ui/Button.astro';
import { resolveImageAlt } from '@/lib/image-alt';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const listingImage = post.listingImage ?? post.image;
---
<article class="overflow-hidden rounded-sm border border-border bg-white lg:flex">
  {listingImage && (
    <a href={getPostHref(post)} class="block lg:w-1/2">
      <ResponsiveImage
        src={listingImage}
        alt={resolveImageAlt(post.imageAlt, post.title)}
        width={640}
        height={500}
        loading="eager"
        fetchpriority="high"
        class="h-full min-h-[280px] w-full object-cover"
      />
    </a>
  )}
  <div class="flex flex-col justify-center p-10 lg:w-1/2 lg:p-16">
    <p class="text-sm text-muted">
      Article à la une · {post.category}
    </p>
    <h2 class="mt-4 font-display text-3xl leading-tight text-ink lg:text-4xl">
      <a href={getPostHref(post)} class="hover:text-brand">{post.title}</a>
    </h2>
    <p class="mt-6 text-lg leading-relaxed text-muted">{post.summary}</p>
    {post.author && (
      <div class="mt-6 flex items-center gap-4">
        <ResponsiveImage
          src={post.author.image}
          alt={post.author.name}
          width={32}
          height={32}
          class="h-8 w-8 rounded-full object-cover"
        />
        <p class="text-sm text-muted">
          Par {post.author.name} · {post.readingTimeMinutes ?? 5} min de lecture
        </p>
      </div>
    )}
    <div class="mt-8">
      <Button href={getPostHref(post)}>Lire l'article →</Button>
    </div>
  </div>
</article>
