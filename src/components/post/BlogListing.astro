---
import Container from '@components/ui/Container.astro';
import {
  blogCategories,
  getFeaturedPost,
  getPublishedPosts,
  postUi,
  postUiEn,
} from '@/data/posts';
import BlogHeader from '@components/post/BlogHeader.astro';
import FilterBar from '@components/post/FilterBar.astro';
import FeaturedPost from '@components/post/FeaturedPost.astro';
import BlogCard from '@components/post/BlogCard.astro';
import Pagination from '@components/post/Pagination.astro';
import type { Lang } from '@/lib/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'fr' } = Astro.props;
const ui = lang === 'en' ? postUiEn : postUi;
const featured = getFeaturedPost(lang);
const posts = getPublishedPosts(lang).filter((p) => !p.featured);
const hasPosts = Boolean(featured) || posts.length > 0;
---
<BlogHeader title={ui.listTitle} subtitle={ui.listSubtitle} />
{hasPosts && <FilterBar categories={blogCategories} />}
<section class="py-16 lg:py-20">
  <Container>
    {!hasPosts ? (
      <p class="rounded-sm border border-dashed border-border bg-bg-card p-10 text-center text-lg text-muted">
        {ui.comingSoon}
      </p>
    ) : (
      <>
        {featured && (
          <div class="mb-16">
            <FeaturedPost post={featured} />
          </div>
        )}
        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
          {posts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
        <Pagination />
      </>
    )}
  </Container>
</section>
