---
import type { Post } from '@/data/posts';
import Container from '@components/ui/Container.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import TextLink from '@components/ui/TextLink.astro';
import BlogCard from '@components/post/BlogCard.astro';
import { getRelatedPosts } from '@/data/posts';
import { renderMarkdown } from '@/lib/markdown';
import { resolveImageAlt } from '@/lib/image-alt';
import type { Lang } from '@/lib/i18n';

interface Props {
  post: Post;
  lang?: Lang;
}

const { post, lang = 'fr' } = Astro.props;
const related = getRelatedPosts(post.relatedSlugs ?? [], lang);
const bodyHtml = post.bodyMarkdown
  ? renderMarkdown(post.bodyMarkdown, { stripLeadingH1: true })
  : '';

const copy =
  lang === 'en'
    ? {
        faq: 'Frequently asked questions',
        toc: 'In this article',
        useful: 'Useful links',
        about: 'About',
        category: 'Category',
        reading: 'Reading time',
        minutes: 'minutes',
        writtenBy: 'Written by',
        allArticles: 'See all articles →',
        related: 'Related articles',
      }
    : {
        faq: 'Questions fréquentes',
        toc: 'Dans cet article',
        useful: 'Liens utiles',
        about: 'À propos',
        category: 'Catégorie',
        reading: 'Lecture',
        minutes: 'minutes',
        writtenBy: 'Rédigé par',
        allArticles: 'Voir tous ses articles →',
        related: 'Articles connexes',
      };
---
{post.image && (
  <div class="w-full">
    <ResponsiveImage
      src={post.image}
      alt={resolveImageAlt(post.imageAlt, post.title)}
      width={1440}
      height={560}
      loading="eager"
      fetchpriority="high"
      sizes="100vw"
      class="aspect-[1440/560] w-full object-cover"
    />
  </div>
)}

<section class="py-16 lg:py-24">
  <Container>
    <div class="grid gap-16 lg:grid-cols-[1fr_360px]">
      <article class="prose-policy max-w-none">
        {bodyHtml ? (
          <div class="holding-body" set:html={bodyHtml} />
        ) : (
          post.sections.map((section) => (
            <div class="mb-12">
              {section.heading && (
                <h2 id={section.id} class="font-display text-3xl text-ink lg:text-4xl">
                  {section.heading}
                </h2>
              )}
              {section.paragraphs.map((p) => (
                <p class:list={['text-lg leading-relaxed text-muted', section.heading && 'mt-6']}>
                  {p}
                </p>
              ))}
              {section.bullets && (
                <ul class="mt-6 space-y-3">
                  {section.bullets.map((item) => (
                    <li class="flex items-start gap-3 text-lg text-muted">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              )}
              {section.callout && (
                <div class="mt-8 rounded-sm border border-brand/20 bg-brand-light p-8 text-lg leading-relaxed text-ink">
                  {section.callout}
                </div>
              )}
              {section.timeline && (
                <ul class="mt-8 space-y-4">
                  {section.timeline.map((item) => (
                    <li class="flex flex-wrap items-baseline gap-3 text-lg">
                      <span class="text-sm font-semibold text-brand">{item.step}</span>
                      <span class="font-medium text-ink">{item.label}</span>
                      <span class="text-muted">{item.timing}</span>
                    </li>
                  ))}
                </ul>
              )}
              {section.link && (
                <TextLink href={section.link.href} class="mt-6 inline-block">
                  {section.link.label}
                </TextLink>
              )}
            </div>
          ))
        )}

        {post.faq && post.faq.length > 0 && (
          <div class="mt-16">
            <h2 id="faq" class="font-display text-3xl text-ink lg:text-4xl">{copy.faq}</h2>
            <dl class="mt-8 space-y-6">
              {post.faq.map((item) => (
                <div class="rounded-sm border border-border bg-bg-card p-6">
                  <dt class="text-lg font-semibold text-ink">{item.question}</dt>
                  <dd class="mt-3 text-lg leading-relaxed text-muted">{item.answer}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}
      </article>

      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        {post.toc && post.toc.length > 0 && (
          <div class="rounded-sm border border-border bg-bg-card p-8">
            <p class="text-sm font-semibold uppercase tracking-wider text-ink">{copy.toc}</p>
            <ul class="mt-4 space-y-3">
              {post.toc.map((item) => (
                <li>
                  <a href={`#${item.id}`} class="text-muted transition-colors hover:text-brand">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {post.usefulLinks && post.usefulLinks.length > 0 && (
          <div class="rounded-sm border border-border bg-bg-card p-8">
            <p class="text-sm font-semibold uppercase tracking-wider text-ink">{copy.useful}</p>
            <ul class="mt-4 space-y-3">
              {post.usefulLinks.map((link) => (
                <li>
                  <TextLink href={link.href}>{link.label}</TextLink>
                </li>
              ))}
            </ul>
          </div>
        )}
        <div class="rounded-sm border border-border bg-bg-card p-8">
          <p class="text-sm font-semibold uppercase tracking-wider text-ink">{copy.about}</p>
          <dl class="mt-4 space-y-4 text-sm">
            <div>
              <dt class="text-muted">{copy.category}</dt>
              <dd class="mt-1 font-medium text-ink">{post.category}</dd>
            </div>
            <div>
              <dt class="text-muted">{copy.reading}</dt>
              <dd class="mt-1 font-medium text-ink">
                {post.readingTimeMinutes ?? 5} {copy.minutes}
              </dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </Container>
</section>

{post.author && (
  <section class="border-t border-border bg-bg-alt py-12">
    <Container>
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
        {post.author.image && (
          <ResponsiveImage
            src={post.author.image}
            alt={post.author.name}
            width={80}
            height={80}
            class="h-20 w-20 rounded-full object-cover"
          />
        )}
        <div>
          <p class="text-xs uppercase tracking-wider text-muted">{copy.writtenBy}</p>
          <p class="mt-2 text-2xl font-semibold text-ink">{post.author.name}</p>
          <p class="mt-3 max-w-3xl text-muted">{post.author.bio}</p>
          <TextLink href={lang === 'en' ? '/en/blog/' : '/blog/'} class="mt-4 inline-block">
            {copy.allArticles}
          </TextLink>
        </div>
      </div>
    </Container>
  </section>
)}

{related.length > 0 && (
  <section class="py-16 lg:py-24">
    <Container>
      <h2 class="font-display text-3xl text-ink lg:text-4xl">{copy.related}</h2>
      <div class="mt-10 grid gap-8 md:grid-cols-2 xl:grid-cols-3">
        {related.map((item) => (
          <BlogCard post={item} />
        ))}
      </div>
    </Container>
  </section>
)}
