---
import Container from '@components/ui/Container.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import FigmaIcon from '@components/ui/FigmaIcon.astro';

interface Props {
  quote: string;
  name: string;
  location: string;
  image: string;
  imageAlt: string;
}

const { quote, name, location, image, imageAlt } = Astro.props;
---
<section class="pb-24 lg:pb-28">
  <Container>
    <div class="overflow-hidden rounded-sm border border-border bg-white lg:flex">
      <div class="lg:w-2/5">
        <ResponsiveImage
          src={image}
          alt={imageAlt}
          width={400}
          height={500}
          class="h-full min-h-[300px] w-full object-cover"
        />
      </div>
      <div class="flex flex-col justify-center p-10 lg:w-3/5 lg:p-16">
        <FigmaIcon name="quote" width={40} height={32} />
        <blockquote class="mt-8 font-display text-2xl leading-relaxed text-ink lg:text-3xl">
          "{quote}"
        </blockquote>
        <footer class="mt-10">
          <p class="font-semibold text-ink">{name}</p>
          <p class="text-muted">{location}</p>
        </footer>
      </div>
    </div>
  </Container>
</section>
