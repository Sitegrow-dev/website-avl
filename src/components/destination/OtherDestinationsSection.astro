---
import type { DestinationCard } from '@/data/destinations';
import Container from '@components/ui/Container.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';

interface Props {
  title: string;
  items: DestinationCard[];
}

const { title, items } = Astro.props;
---
<section class="bg-bg-alt py-24 lg:py-28">
  <Container>
    <h2 class="font-display text-4xl text-ink lg:text-[52px]">{title}</h2>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 xl:grid-cols-4">
      {items.map((item) => (
        <a href={item.href} class="group block overflow-hidden rounded-sm bg-white">
          <ResponsiveImage
            src={item.image}
            alt={item.imageAlt}
            width={296}
            height={240}
            class="aspect-[296/240] w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="p-6">
            <p class="text-xs uppercase tracking-wider text-brand">{item.eyebrow}</p>
            <h3 class="mt-2 font-display text-2xl text-ink">{item.title}</h3>
            <span class="mt-4 inline-block text-sm text-brand">Découvrir →</span>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>
