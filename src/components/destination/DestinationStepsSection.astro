---
import Container from '@components/ui/Container.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import TextLink from '@components/ui/TextLink.astro';
import FigmaIcon from '@components/ui/FigmaIcon.astro';

interface StepItem {
  step: string;
  icon: string;
  title: string;
  description: string;
  link: { label: string; href: string };
}

interface Props {
  eyebrow: string;
  title: string;
  items: StepItem[];
}

const { eyebrow, title, items } = Astro.props;
---
<section class="py-24 lg:py-28">
  <Container>
    <SectionHeader eyebrow={eyebrow} title={title} />
    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {items.map((item) => (
        <article class="rounded-sm border border-border bg-bg-card p-10">
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold text-brand">{item.step}</span>
            <FigmaIcon name={item.icon} size={32} />
          </div>
          <h3 class="mt-10 text-2xl font-semibold text-ink">{item.title}</h3>
          <p class="mt-4 text-muted">{item.description}</p>
          <TextLink href={item.link.href} class="mt-8 inline-block">{item.link.label}</TextLink>
        </article>
      ))}
    </div>
  </Container>
</section>
