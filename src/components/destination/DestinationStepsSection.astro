---
import Container from '@components/ui/Container.astro';
import SectionHeader from '@components/ui/SectionHeader.astro';
import TextLink from '@components/ui/TextLink.astro';

interface StepItem {
  step: string;
  icon: string;
  title: string;
  description: string;
  link: { label: string; href: string };
}

interface Props {
  eyebrow: string;
  title: string;
  items: StepItem[];
}

const { eyebrow, title, items } = Astro.props;

const icons: Record<string, string> = {
  'file-check': '<path d="M14 2H6a2 2 0 0 0-2 2v16l4-2 4 2 4-2 4 2V8l-6-6Z"/>',
  church: '<path d="M12 2 4 7v2h16V7L12 2Zm-1 4h2v2h-2V6Zm-3 9v7h2v-5h6v5h2v-7l-5-3-5 3Z"/>',
  plane: '<path d="M2 12h5l3 7 4-14 3 7h5"/>',
};
---
<section class="py-24 lg:py-28">
  <Container>
    <SectionHeader eyebrow={eyebrow} title={title} />
    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {items.map((item) => (
        <article class="rounded-sm border border-border bg-bg-card p-10">
          <div class="flex items-center justify-between">
            <span class="text-sm font-semibold text-brand">{item.step}</span>
            <svg class="h-8 w-8 text-brand" viewBox="0 0 24 24" fill="currentColor" set:html={icons[item.icon]} />
          </div>
          <h3 class="mt-10 text-2xl font-semibold text-ink">{item.title}</h3>
          <p class="mt-4 text-muted">{item.description}</p>
          <TextLink href={item.link.href} class="mt-8 inline-block">{item.link.label}</TextLink>
        </article>
      ))}
    </div>
  </Container>
</section>
