---
import { getContactContent, type ContactRichPart } from '@/data/contact';
import { siteConfig } from '@/config/site';
import { PUBLIC_FORMSPREE_ID } from 'astro:env/client';
import { resolveLang } from '@/lib/i18n';

const lang = resolveLang(Astro.currentLocale, Astro.url.pathname);
const content = getContactContent(lang);
const {
  title,
  intro,
  advice,
  reasonsTitle,
  reasons,
  expectations,
  cannot,
  writeTitle,
  emailNote,
  disclaimer,
  topics,
  form,
} = content;
const formspreeId = PUBLIC_FORMSPREE_ID?.trim();
const endpoint = formspreeId ? `https://formspree.io/f/${formspreeId}` : null;
const subjectPrefix = lang === 'en' ? 'New message' : 'Nouveau message';

function isLinkPart(part: ContactRichPart): part is { label: string; href: string } {
  return typeof part === 'object' && part !== null && 'href' in part;
}
---

<section class="px-5 pb-10 pt-16 sm:px-8 sm:pb-12 sm:pt-20 lg:px-10">
  <div class="mx-auto max-w-3xl">
    <h1 class="font-display text-4xl leading-tight text-ink sm:text-5xl lg:text-[52px] lg:leading-[1.1]">
      {title}
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-muted">{intro}</p>
  </div>
</section>

<section class="border-y border-black/[0.08] bg-surface px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{advice.title}</h2>
    <p class="mt-5 text-lg leading-relaxed text-muted">{advice.text}</p>
  </div>
</section>

<section class="px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{reasonsTitle}</h2>
    <div class="mt-10 space-y-12">
      {reasons.map((reason) => (
        <article>
          <h3 class="text-xl font-bold text-ink sm:text-2xl">{reason.title}</h3>
          <p class="mt-3 text-base font-medium leading-relaxed text-ink/80">{reason.summary}</p>
          {reason.paragraphs.map((parts) => (
            <p class="mt-4 text-base leading-relaxed text-muted">
              {parts.map((part) =>
                isLinkPart(part) ? (
                  <a href={part.href} class="font-medium text-brand underline-offset-2 hover:underline">
                    {part.label}
                  </a>
                ) : (
                  part
                ),
              )}
            </p>
          ))}
        </article>
      ))}
    </div>
  </div>
</section>

<section class="border-y border-black/[0.08] bg-surface px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{expectations.title}</h2>
    <ul class="mt-8 space-y-4">
      {expectations.items.map((item) => (
        <li class="flex gap-3 text-base leading-relaxed text-muted">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<section class="px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
  <div class="mx-auto max-w-3xl">
    <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{cannot.title}</h2>
    <p class="mt-5 text-lg leading-relaxed text-muted">{cannot.intro}</p>
    <ul class="mt-8 space-y-5">
      {cannot.items.map((item) => (
        <li class="flex gap-3 text-base leading-relaxed text-muted">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ink/30" aria-hidden="true"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
    <p class="mt-8 text-base leading-relaxed text-ink">{cannot.closing}</p>
  </div>
</section>

<section id="ecrire" class="border-t border-black/[0.08] bg-surface px-5 py-14 sm:px-8 sm:py-16 lg:px-10">
  <div class="mx-auto max-w-2xl">
    <h2 class="font-display text-3xl leading-tight text-ink sm:text-4xl">{writeTitle}</h2>

    {endpoint ? (
      <form
        id="contact-form"
        class="mt-8 flex flex-col gap-5"
        action={endpoint}
        method="POST"
        data-endpoint={endpoint}
        data-submitting={form.submitting}
        data-submit={form.submit}
        data-success-title={form.successTitle}
        data-success-message={form.successMessage}
        data-success-reset={form.successReset}
        data-error-generic={form.errorGeneric}
        data-error-network={form.errorNetwork}
        data-error-validation={form.errorValidation}
        data-required-name={form.requiredName}
        data-required-email={form.requiredEmail}
        data-invalid-email={form.invalidEmail}
        data-required-message={form.requiredMessage}
        novalidate
      >
        <p
          id="contact-status"
          role="status"
          aria-live="polite"
          class="hidden rounded-md border px-4 py-3 text-sm"
        >
        </p>

        <input type="hidden" name="_subject" value={`${subjectPrefix} : ${siteConfig.siteName}`} />
        {/* Formspree : désactive le captcha côté service (on s'en remet à son filtre anti-spam intégré) */}
        <input type="hidden" name="_captcha" value="false" />

        <div>
          <label class="mb-2 block text-sm font-semibold text-ink" for="contact-name">{form.name}</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            autocomplete="name"
            required
            class="contact-field w-full rounded-md border border-black/[0.08] bg-white px-4 py-3 text-base text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
          />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-ink" for="contact-email">{form.email}</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            autocomplete="email"
            required
            class="contact-field w-full rounded-md border border-black/[0.08] bg-white px-4 py-3 text-base text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
          />
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-ink" for="contact-topic">{form.topic}</label>
          <select
            id="contact-topic"
            name="topic"
            class="contact-field w-full rounded-md border border-black/[0.08] bg-white px-4 py-3 text-base text-ink focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
          >
            {topics.map((topic) => (
              <option value={topic.value}>{topic.label}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-ink" for="contact-message">{form.message}</label>
          <textarea
            id="contact-message"
            name="message"
            rows="5"
            required
            placeholder={form.placeholder}
            class="contact-field w-full resize-y rounded-md border border-black/[0.08] bg-white px-4 py-3 text-base text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
          ></textarea>
        </div>
        <button
          type="submit"
          id="contact-submit"
          class="inline-flex items-center justify-center rounded-md bg-brand px-6 py-3.5 text-base font-semibold text-white shadow-[0_4px_7px_rgba(0,0,0,0.1)] transition-colors hover:bg-brand-hover disabled:cursor-not-allowed disabled:opacity-60"
        >
          {form.submit}
        </button>
      </form>
    ) : (
      <div class="mt-8 rounded-lg border border-dashed border-brand/40 bg-brand-light p-6">
        <p class="text-base font-semibold text-ink">{form.notConfiguredTitle}</p>
        <p class="mt-2 text-sm leading-relaxed text-muted">{form.notConfiguredMessage}</p>
        <a
          href={`mailto:${siteConfig.contactEmail}`}
          class="mt-4 inline-flex items-center justify-center rounded-md bg-brand px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-brand-hover"
        >
          {form.fallbackCta}
        </a>
      </div>
    )}

    <p class="mt-8 text-base leading-relaxed text-muted">
      {emailNote}{' '}
      <a
        href={`mailto:${siteConfig.contactEmail}`}
        class="font-medium text-brand underline-offset-2 hover:underline"
      >
        {siteConfig.contactEmail}
      </a>.
    </p>
  </div>
</section>

<section class="border-t border-black/[0.08] px-5 py-12 sm:px-8 lg:px-10">
  <div class="mx-auto max-w-3xl">
    <p class="text-sm leading-relaxed text-muted">{disclaimer}</p>
  </div>
</section>

<script>
  function initContactForm() {
    const formEl = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!formEl || formEl.dataset.formInit === 'true') return;
    const form: HTMLFormElement = formEl;
    form.dataset.formInit = 'true';

    const endpointValue = form.dataset.endpoint;
    if (!endpointValue) return;
    const endpoint: string = endpointValue;

    const statusEl = document.getElementById('contact-status') as HTMLElement;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;

    const labels = {
      submitting: form.dataset.submitting || 'Envoi…',
      submit: form.dataset.submit || 'Envoyer',
      successTitle: form.dataset.successTitle || 'Message envoyé',
      successMessage: form.dataset.successMessage || 'Merci !',
      successReset: form.dataset.successReset || 'Envoyer un autre message',
      errorGeneric: form.dataset.errorGeneric || 'Une erreur est survenue.',
      errorNetwork: form.dataset.errorNetwork || 'Connexion impossible.',
      errorValidation: form.dataset.errorValidation || 'Veuillez corriger les champs indiqués.',
      requiredName: form.dataset.requiredName || 'Veuillez indiquer votre nom.',
      requiredEmail: form.dataset.requiredEmail || 'Veuillez indiquer votre adresse courriel.',
      invalidEmail: form.dataset.invalidEmail || 'Veuillez indiquer une adresse courriel valide.',
      requiredMessage: form.dataset.requiredMessage || 'Veuillez écrire votre message.',
    };

    type FieldErrors = Record<string, string>;

    function setStatus(kind: 'error' | 'success' | 'idle', message: string) {
      statusEl.textContent = message;
      statusEl.classList.remove('hidden');
      if (kind === 'error') {
        statusEl.className =
          'rounded-md border border-red-200 bg-red-50 text-red-700 px-4 py-3 text-sm';
      } else if (kind === 'success') {
        statusEl.className =
          'rounded-md border border-green-200 bg-green-50 text-green-700 px-4 py-3 text-sm';
      } else {
        statusEl.className = 'hidden rounded-md border px-4 py-3 text-sm';
      }
    }

    function clearFieldErrors() {
      form.querySelectorAll<HTMLElement>('.contact-field').forEach((field) => {
        field.removeAttribute('aria-invalid');
        field.classList.remove('border-red-400');
        if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
          field.setCustomValidity('');
        }
        const next = field.parentElement?.querySelector('[data-field-error]');
        if (next) next.remove();
      });
    }

    function showFieldErrors(errors: FieldErrors) {
      const invalidFields: HTMLElement[] = [];
      Object.entries(errors).forEach(([name, msg]) => {
        const field = form.querySelector<HTMLElement>(`[name="${name}"]`);
        if (!field) return;
        field.setAttribute('aria-invalid', 'true');
        field.classList.add('border-red-400');
        if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
          field.setCustomValidity(msg);
        }
        const errEl = document.createElement('p');
        errEl.className = 'mt-1.5 text-sm text-red-600';
        errEl.dataset.fieldError = 'true';
        errEl.setAttribute('role', 'alert');
        errEl.textContent = msg;
        field.parentElement?.appendChild(errEl);
        invalidFields.push(field);
      });
      invalidFields[0]?.focus();
    }

    function validateClient(): boolean {
      clearFieldErrors();
      const errors: FieldErrors = {};

      const nameField = form.elements.namedItem('name');
      const emailField = form.elements.namedItem('email');
      const messageField = form.elements.namedItem('message');

      const nameValue =
        nameField instanceof HTMLInputElement ? nameField.value.trim() : '';
      const emailValue =
        emailField instanceof HTMLInputElement ? emailField.value.trim() : '';
      const messageValue =
        messageField instanceof HTMLTextAreaElement ? messageField.value.trim() : '';

      if (!nameValue) errors.name = labels.requiredName;
      if (!emailValue) {
        errors.email = labels.requiredEmail;
      } else if (
        emailField instanceof HTMLInputElement &&
        !emailField.checkValidity()
      ) {
        errors.email = labels.invalidEmail;
      }
      if (!messageValue) errors.message = labels.requiredMessage;

      if (Object.keys(errors).length > 0) {
        showFieldErrors(errors);
        setStatus('error', labels.errorValidation);
        return false;
      }

      // Sync trimmed values so Formspree receives non-whitespace content
      if (nameField instanceof HTMLInputElement) nameField.value = nameValue;
      if (emailField instanceof HTMLInputElement) emailField.value = emailValue;
      if (messageField instanceof HTMLTextAreaElement) messageField.value = messageValue;

      return form.checkValidity();
    }

    async function handleSubmit(event: SubmitEvent) {
      event.preventDefault();

      if (!validateClient()) {
        return;
      }

      clearFieldErrors();
      submitBtn.disabled = true;
      submitBtn.textContent = labels.submitting;
      setStatus('idle', '');

      const data = new FormData(form);

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          setStatus(
            'success',
            `${labels.successTitle} ${labels.successMessage}`,
          );
          form.reset();
          const formWrapper = form;
          formWrapper.style.display = 'none';

          const resetBtn = document.createElement('button');
          resetBtn.type = 'button';
          resetBtn.className =
            'mt-4 inline-flex items-center justify-center rounded-md border border-black/[0.08] bg-white px-5 py-2.5 text-sm font-semibold text-ink transition-colors hover:bg-gray-50';
          resetBtn.textContent = labels.successReset;
          resetBtn.onclick = () => {
            formWrapper.style.display = '';
            statusEl.classList.add('hidden');
            resetBtn.remove();
            submitBtn.disabled = false;
            submitBtn.textContent = labels.submit;
          };
          statusEl.parentElement?.appendChild(resetBtn);
          return;
        }

        // Validation côté serveur
        let errors: FieldErrors = {};
        try {
          const body = await res.json();
          if (body?.errors && Array.isArray(body.errors)) {
            errors = Object.fromEntries(
              body.errors
                .filter((e: { field?: string }) => e.field)
                .map((e: { field?: string; message?: string }) => [
                  e.field,
                  e.message || 'Champ invalide.',
                ]),
            );
          }
        } catch {
          // Réponse non-JSON (ex. 5xx HTML) : erreur générique
        }

        if (Object.keys(errors).length > 0) {
          showFieldErrors(errors);
          setStatus('error', labels.errorGeneric);
        } else {
          setStatus('error', labels.errorGeneric);
        }
      } catch {
        setStatus('error', labels.errorNetwork);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = labels.submit;
      }
    }

    form.addEventListener('submit', handleSubmit);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }
  document.addEventListener('astro:page-load', initContactForm);
</script>
