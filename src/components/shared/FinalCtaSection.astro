---
import Container from '@components/ui/Container.astro';
import Button from '@components/ui/Button.astro';

interface Props {
  title?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title = 'Prêts à commencer ?',
  ctaLabel = 'Nous contacter',
  ctaHref = '/contact/',
} = Astro.props;
---
<section class="bg-bg-alt py-24 lg:py-28">
  <Container class="text-center">
    <h2 class="font-display text-4xl text-ink lg:text-[52px]">{title}</h2>
    <div class="mt-10">
      <Button href={ctaHref}>{ctaLabel}</Button>
    </div>
  </Container>
</section>
