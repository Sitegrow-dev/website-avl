---
/**
 * Sélecteur de langue : affiche uniquement l’autre langue disponible
 * lorsqu’un miroir indexable existe (même règle que hreflang / SeoHead).
 * Attribut hreflang en BCP 47 régional (fr-CA / en-CA).
 */
import { siteConfig } from '@/config/site';
import { alternatePath, hasEnAlternate, htmlLang, type Lang } from '@/lib/i18n';

interface Props {
  lang: Lang;
  /** Chemin public (canonique) pour calculer l’URL alternative. */
  path?: string;
  /** Classes supplémentaires (ex. menu mobile). */
  class?: string;
}

const { lang, path, class: className = '' } = Astro.props;
const pathname = path ?? Astro.url.pathname;
const otherLang: Lang = lang === 'fr' ? 'en' : 'fr';
/** Pas de lien vers une page EN absente / non indexable (ex. destinations). */
const showSwitcher =
  otherLang === 'fr' || (siteConfig.enIndexable && hasEnAlternate(pathname));
const href = alternatePath(pathname, otherLang);
const label = lang === 'en' ? 'Language' : 'Langue';
const linkText = otherLang.toUpperCase();
const otherHreflang = htmlLang(otherLang);
---
{showSwitcher && (
  <nav class:list={['flex items-center gap-1 text-sm font-semibold', className]} aria-label={label}>
    <a
      href={href}
      lang={otherHreflang}
      hreflang={otherHreflang}
      class="rounded px-2 py-1 text-muted transition-colors hover:text-ink"
    >
      {linkText}
    </a>
  </nav>
)}
