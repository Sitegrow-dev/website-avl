---
import { getSearchContent } from '@/data/search';
import { type Lang } from '@/lib/i18n';

interface Props {
  lang?: Lang;
  /** Prefill from URL. */
  query?: string;
  class?: string;
  autofocus?: boolean;
}

const {
  lang = 'fr',
  query = '',
  class: className = '',
  autofocus = false,
} = Astro.props;

const copy = getSearchContent(lang);
---
<form
  action={copy.path}
  method="get"
  role="search"
  class:list={['w-full', className]}
>
  <label class="sr-only" for="site-search-page">{copy.submit}</label>
  <div class="flex w-full items-center gap-2 rounded-sm border border-black/[0.12] bg-white shadow-sm">
    <span class="pl-3 text-ink/45" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="M20 20l-3.5-3.5"></path>
      </svg>
    </span>
    <input
      id="site-search-page"
      type="search"
      name="q"
      value={query}
      placeholder={copy.placeholder}
      autocomplete="off"
      enterkeyhint="search"
      autofocus={autofocus || undefined}
      class="min-w-0 flex-1 bg-transparent py-3.5 pr-3 text-base text-ink outline-none placeholder:text-ink/40"
    />
    <button
      type="submit"
      class="shrink-0 rounded-r-[1px] bg-brand px-5 py-3.5 text-sm font-semibold uppercase tracking-wide text-white transition-colors hover:bg-brand-hover"
    >
      {copy.submit}
    </button>
  </div>
</form>
