# Site Configuration
SITE_URL=https://afvl.org
SITE_DOMAIN=afvl.org

CONTACT_EMAIL=contact@afvl.org

# Formspree : ID du formulaire uniquement (pas l’URL complète)
# Exemple : pour https://formspree.io/f/mvzepagn → PUBLIC_FORMSPREE_ID=mvzepagn
# Créez un formulaire sur https://formspree.io/forms
PUBLIC_FORMSPREE_ID=

# Holding Sitegrow : clé API du site (admin Holding → Sites)
# Doc : https://holding.sitegrow.ca/docs
# Sans clé : blog vide (pas de données mock)
HOLDING_API_KEY=
# HOLDING_API_URL=https://holding.sitegrow.ca

# Port for local development
PORT=4325

# Enable HTTPS in dev (requires accepting self-signed cert in browser)
# DEV_HTTPS=true
